<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ringing ripple background -->
    <FrameLayout
        android:id="@+id/ringing_animation_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/ripple_1"
            android:layout_width="210dp"
            android:layout_height="210dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ripple_ring"
            android:alpha="0.28" />

        <View
            android:id="@+id/ripple_2"
            android:layout_width="270dp"
            android:layout_height="270dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ripple_ring"
            android:alpha="0.18" />

        <View
            android:id="@+id/ripple_3"
            android:layout_width="330dp"
            android:layout_height="330dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ripple_ring"
            android:alpha="0.10" />

    </FrameLayout>

    <!-- Call type indicator -->
    <TextView
        android:id="@+id/tv_call_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="Incoming Video Call"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/md3_primary"
        android:letterSpacing="0.15"
        android:layout_marginTop="42dp"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Caller info card -->
    <LinearLayout
        android:id="@+id/caller_info_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:background="@drawable/bg_obsidian_card"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="30dp"
        android:gravity="center"
        android:elevation="16dp"
        android:translationZ="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_call_type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_caller_avatar"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/ic_profile_placeholder"
            android:elevation="14dp"
            android:translationZ="10dp"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="3dp" />

        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textColor="@color/md3_on_surface"
            android:textSize="27sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_caller_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="is calling you..."
            android:textColor="@color/md3_on_surface_secondary"
            android:textSize="17sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:minWidth="78dp"
            android:gravity="center"
            android:text="00:00"
            android:textColor="@color/md3_on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_icon_circle_dark"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Outgoing call info -->
    <LinearLayout
        android:id="@+id/outgoing_call_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_soft_inset"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toBottomOf="@id/caller_info_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calling..."
            android:textColor="@color/md3_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ringing_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ringing"
            android:textColor="@color/md3_on_surface_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Swipe Action Card -->
    <LinearLayout
        android:id="@+id/swipe_action_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="42dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@android:color/transparent"
        android:elevation="16dp"
        android:translationZ="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swipe to answer or decline"
            android:textSize="15sp"
            android:textColor="@color/md3_on_surface"
            android:layout_marginBottom="14dp"
            android:gravity="center" />

        <!-- Swipe Track Container -->
        <FrameLayout
            android:id="@+id/swipe_track"
            android:layout_width="300dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_soft_inset"
            android:elevation="12dp"
            android:translationZ="8dp">

            <!-- Accept Zone -->
            <View
                android:id="@+id/accept_zone"
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="@drawable/swipe_accept_zone"
                android:alpha="0.25" />

            <!-- Decline Zone -->
            <View
                android:id="@+id/decline_zone"
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="@drawable/swipe_decline_zone"
                android:alpha="0.25" />

            <!-- Decline Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="22dp"
                android:text="Decline"
                android:textColor="@color/md3_error"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Accept Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="24dp"
                android:text="Accept"
                android:textColor="@color/md3_on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Swipe Thumb -->
            <FrameLayout
                android:id="@+id/swipe_thumb"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_call_accept_circle"
                android:elevation="16dp"
                android:translationZ="12dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_call"
                    app:tint="@color/md3_on_surface" />

            </FrameLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>