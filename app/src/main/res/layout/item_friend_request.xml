<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_list_row_divider"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingStart="@dimen/margin_mobile"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingEnd="@dimen/margin_mobile"
    android:paddingBottom="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/civ_profile_picture"
            android:layout_width="@dimen/avatar_sm"
            android:layout_height="@dimen/avatar_sm"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_color="@color/md3_border_subtle"
            app:civ_border_width="@dimen/avatar_border_width_sm" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="1"
                android:textColor="@color/md3_on_surface"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold"
                tools:text="Fong Nguyen" />

            <TextView
                android:id="@+id/tv_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="1"
                android:textColor="@color/md3_on_surface_secondary"
                android:textSize="@dimen/text_body_small"
                tools:text="fong.nguyen@example.com" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_action_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_reject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:background="@drawable/bg_reject_button_modern"
            android:backgroundTint="@null"
            android:minWidth="86dp"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:text="@string/action_reject"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:textSize="@dimen/text_body_small"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_accept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:minHeight="@dimen/touch_target_min"
            android:background="@drawable/bg_accept_button_modern"
            android:backgroundTint="@null"
            android:minWidth="86dp"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:text="@string/action_accept"
            android:textAllCaps="false"
            android:textColor="@color/md3_on_surface"
            android:textSize="@dimen/text_body_small"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_sent_request_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_md"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/md3_on_surface_secondary"
            android:textSize="@dimen/text_body_small"
            android:textStyle="bold"
            tools:text="Pending" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:background="@drawable/bg_reject_button_modern"
            android:backgroundTint="@null"
            android:minWidth="86dp"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:text="@string/action_cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:textSize="@dimen/text_body_small"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
