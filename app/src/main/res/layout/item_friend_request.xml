<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:orientation="vertical">

    <!-- Card item -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_empty_state_panel"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp"
        android:elevation="10dp"
        android:translationZ="6dp">

        <!-- Avatar + Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/civ_profile_picture"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_profile_placeholder"
                android:elevation="8dp"
                android:translationZ="5dp"
                app:civ_border_color="#33FFFFFF"
                app:civ_border_width="1.5dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Fong Nguyen" />

                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#9AA4B2"
                    android:textSize="12sp"
                    tools:text="fong.nguyen@example.com" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:id="@+id/ll_action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_reject"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="86dp"
                android:text="Reject"
                android:textAllCaps="false"
                android:textColor="#FF4D57"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reject_button_modern"
                android:backgroundTint="@null"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:elevation="8dp"
                android:translationZ="5dp"
                android:stateListAnimator="@animator/btn_shadow_animator" />

            <Button
                android:id="@+id/btn_accept"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="86dp"
                android:layout_marginStart="10dp"
                android:text="Accept"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_accept_button_modern"
                android:backgroundTint="@null"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:elevation="10dp"
                android:translationZ="6dp"
                android:stateListAnimator="@animator/btn_shadow_animator" />

        </LinearLayout>

        <!-- Sent request actions -->
        <LinearLayout
            android:id="@+id/ll_sent_request_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="gone">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:textColor="#9AA4B2"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Pending" />

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="86dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#FF4D57"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reject_button_modern"
                android:backgroundTint="@null"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:elevation="8dp"
                android:translationZ="5dp"
                android:stateListAnimator="@animator/btn_shadow_animator" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>