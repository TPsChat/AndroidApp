<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_obsidian_card">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/md3_on_surface"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message"
            android:textSize="15sp"
            android:textColor="@color/md3_on_surface"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="22dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_negative"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="92dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/dialog_button_secondary_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reject_button_modern"
                android:backgroundTint="@null"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <Space
                android:layout_width="10dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_positive"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="92dp"
                android:text="OK"
                android:textAllCaps="false"
                android:textColor="@color/dialog_button_filled_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_new_message_button"
                android:backgroundTint="@null"
                android:paddingStart="22dp"
                android:paddingEnd="22dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>