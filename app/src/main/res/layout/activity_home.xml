<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        android:contentDescription="Background Image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="40dp" />

    <!-- Search Bar Floating -->
    <LinearLayout
        android:id="@+id/search_bar_home"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_message_field_shadow"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="12dp"
            app:tint="#FF4D57"
            android:contentDescription="Search Icon" />

        <TextView
            android:id="@+id/tv_search_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Search"
            android:textSize="15sp"
            android:textColor="#7F8A99"
            android:gravity="center_vertical" />

    </LinearLayout>

    <!-- User Profile Section -->
    <LinearLayout
        android:id="@+id/user_profile_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_empty_state_panel"
        android:paddingStart="14dp"
        android:paddingEnd="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_user_avatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_profile_placeholder"
            android:contentDescription="User Avatar"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_color="#33FFFFFF"
            app:civ_border_width="1.5dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxWidth="150dp"
                android:text="User Name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Create Post Bar -->
    <LinearLayout
        android:id="@+id/ll_create_post_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="@drawable/bg_empty_state_panel"
        android:padding="14dp"
        android:visibility="gone"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toBottomOf="@id/search_bar_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_post_profile_thumbnail"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_profile_placeholder"
                android:elevation="8dp"
                android:translationZ="5dp"
                app:civ_border_color="#33FFFFFF"
                app:civ_border_width="1.5dp" />

            <LinearLayout
                android:id="@+id/ll_create_post_input"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_message_field_shadow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tv_create_post_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What's on your mind?"
                    android:textColor="#9AA4B2"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/ll_live_post"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#FF4D57" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Live"
                    android:textColor="#D7DEE8"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_photo_post"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#FF4D57" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Photo"
                    android:textColor="#D7DEE8"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_video_post"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_video_call"
                    app:tint="#FF4D57" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Video"
                    android:textColor="#D7DEE8"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Friend Requests / Friends Entry -->
    <LinearLayout
        android:id="@+id/ll_friend_requests"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_message_field_shadow"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="14dp"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toBottomOf="@id/search_bar_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_requests_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Friends"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_friend_request_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_red_modern"
            android:gravity="center"
            android:minWidth="24dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_more"
            app:tint="#D7DEE8"
            android:contentDescription="More Options" />

    </LinearLayout>

    <!-- Main List -->
    <LinearLayout
        android:id="@+id/chat_list_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/ll_friend_requests"
        app:layout_constraintBottom_toTopOf="@id/tab_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/ll_posts_action_bar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:padding="0dp">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipe_refresh_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_chat_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:scrollbars="none"
                    android:background="@android:color/transparent" />

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:padding="6dp"
        android:background="@drawable/bg_message_field_shadow"
        android:elevation="16dp"
        android:translationZ="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_chats"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:src="@drawable/ic_chat"
            app:tint="@color/tab_icon_selector"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:contentDescription="Chats" />

        <ImageView
            android:id="@+id/iv_groups"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:src="@drawable/ic_group"
            app:tint="@color/tab_icon_selector"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:contentDescription="Groups" />

        <ImageView
            android:id="@+id/iv_calls"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:src="@drawable/ic_call"
            app:tint="@color/tab_icon_selector"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:contentDescription="Calls" />

        <ImageView
            android:id="@+id/iv_posts"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:src="@drawable/ic_post"
            app:tint="@color/tab_icon_selector"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:contentDescription="Posts" />

        <ImageView
            android:id="@+id/iv_notifications"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:src="@drawable/ic_notification"
            app:tint="@color/tab_icon_selector"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:contentDescription="Notifications" />

        <ImageView
            android:id="@+id/iv_settings"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:src="@drawable/ic_setting"
            app:tint="@color/tab_icon_selector"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- Floating Action Button -->
    <ImageButton
        android:id="@+id/efab_new_group"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:visibility="gone"
        android:background="@drawable/bg_send_circle_modern"
        android:contentDescription="@string/create_group_description"
        android:src="@drawable/ic_add"
        android:padding="13dp"
        android:scaleType="centerInside"
        android:elevation="16dp"
        android:translationZ="12dp"
        android:stateListAnimator="@animator/btn_shadow_animator"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/tab_container"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>