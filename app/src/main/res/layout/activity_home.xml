<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.08"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Home header: avatar + title + action -->
    <LinearLayout
        android:id="@+id/user_profile_section"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_user_avatar"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:contentDescription="@string/home_user_avatar_cd"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="@dimen/avatar_border_width" />

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans"
            android:maxLines="1"
            android:text="@string/home_title_chats"
            android:textAppearance="@style/AppScreenTitle"
            android:textColor="@color/md3_on_surface"
            tools:text="Chats" />

        <ImageButton
            android:id="@+id/efab_new_group"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@drawable/bg_header_fab"
            android:contentDescription="@string/create_group_description"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_add"
            app:tint="@color/md3_primary" />

    </LinearLayout>

    <!-- Search affordance -->
    <LinearLayout
        android:id="@+id/search_bar_home"
        android:layout_width="0dp"
        android:layout_height="@dimen/search_bar_height"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:background="@drawable/bg_glass_search"
        android:clickable="true"
        android:contentDescription="@string/home_search_bar_cd"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/user_profile_section">

        <ImageView
            android:layout_width="@dimen/icon_search"
            android:layout_height="@dimen/icon_search"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:contentDescription="@string/search_icon_description"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_search"
            app:tint="@color/md3_secondary" />

        <TextView
            android:id="@+id/tv_search_hint"
            style="@style/AppBodyMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/search_hint"
            android:textColor="@color/md3_on_surface_secondary" />

    </LinearLayout>

    <include
        android:id="@+id/ll_create_post_bar"
        layout="@layout/component_create_post_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_bar_home" />

    <!-- Friend requests row -->
    <LinearLayout
        android:id="@+id/ll_friend_requests"
        android:layout_width="0dp"
        android:layout_height="@dimen/touch_target_min"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:background="@drawable/bg_obsidian_card"
        android:clickable="true"
        android:contentDescription="@string/home_friend_requests_cd"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_bar_home">

        <TextView
            android:id="@+id/tv_requests_title"
            android:importantForAccessibility="no"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/home_friends_title"
            android:textColor="@color/md3_on_surface"
            android:textSize="@dimen/text_body_large"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_friend_request_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_red_modern"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:importantForAccessibility="no"
            android:minWidth="@dimen/badge_min_width"
            android:paddingStart="@dimen/badge_padding_h"
            android:paddingEnd="@dimen/badge_padding_h"
            android:paddingTop="@dimen/badge_padding_v"
            android:paddingBottom="@dimen/badge_padding_v"
            android:text="@string/badge_count_placeholder"
            android:textColor="@color/md3_on_primary"
            android:textSize="@dimen/text_label_small"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageView
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:layout_marginStart="@dimen/spacing_xs"
            android:contentDescription="@string/home_more_options_cd"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_more"
            app:tint="@color/md3_secondary" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/chat_list_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_xs"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/tab_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_friend_requests">

        <LinearLayout
            android:id="@+id/ll_posts_action_bar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_chat_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clipToPadding="false"
                    android:paddingTop="@dimen/spacing_xs"
                    android:paddingBottom="@dimen/list_content_padding_bottom"
                    android:scrollbars="none" />

                <include
                    android:id="@+id/home_empty_state"
                    layout="@layout/component_empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- Flat dock bottom nav -->
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="0dp"
        android:layout_height="@dimen/nav_bar_height"
        android:background="@drawable/bg_glass_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_xs"
        android:paddingEnd="@dimen/spacing_xs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_chats"
            android:layout_width="0dp"
            android:layout_height="@dimen/nav_tab_height"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:contentDescription="@string/tab_chats_cd"
            android:focusable="true"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_chat"
            app:tint="@color/tab_icon_selector" />

        <ImageView
            android:id="@+id/iv_groups"
            android:layout_width="0dp"
            android:layout_height="@dimen/nav_tab_height"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:contentDescription="@string/tab_groups_cd"
            android:focusable="true"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_group"
            app:tint="@color/tab_icon_selector" />

        <ImageView
            android:id="@+id/iv_calls"
            android:layout_width="0dp"
            android:layout_height="@dimen/nav_tab_height"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:contentDescription="@string/tab_calls_cd"
            android:focusable="true"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_call"
            app:tint="@color/tab_icon_selector" />

        <ImageView
            android:id="@+id/iv_posts"
            android:layout_width="0dp"
            android:layout_height="@dimen/nav_tab_height"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:contentDescription="@string/tab_posts_cd"
            android:focusable="true"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_post"
            app:tint="@color/tab_icon_selector" />

        <ImageView
            android:id="@+id/iv_notifications"
            android:layout_width="0dp"
            android:layout_height="@dimen/nav_tab_height"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:contentDescription="@string/tab_notifications_cd"
            android:focusable="true"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_notification"
            app:tint="@color/tab_icon_selector" />

        <ImageView
            android:id="@+id/iv_settings"
            android:layout_width="0dp"
            android:layout_height="@dimen/nav_tab_height"
            android:layout_weight="1"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:contentDescription="@string/tab_settings_cd"
            android:focusable="true"
            android:padding="@dimen/nav_tab_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_setting"
            app:tint="@color/tab_icon_selector" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
