<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="14dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Vertical Line Indicator -->
    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:minHeight="46dp"
        android:layout_marginEnd="12dp"
        android:background="#55FF4D57" />

    <!-- Reply Content Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="top"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- User Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_reply_avatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_profile_placeholder"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_color="#33FFFFFF"
            app:civ_border_width="1.2dp" />

        <!-- Reply Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="9dp"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false">

            <!-- Reply Bubble -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="110dp"
                android:maxWidth="260dp"
                android:orientation="vertical"
                android:paddingStart="13dp"
                android:paddingEnd="13dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@drawable/bg_option_row_dark"
                android:elevation="8dp"
                android:translationZ="5dp">

                <!-- Username -->
                <TextView
                    android:id="@+id/tv_reply_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="220dp"
                    android:text="Username"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingBottom="3dp" />

                <!-- Reply Text Body -->
                <TextView
                    android:id="@+id/tv_reply_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:text="This is a reply to the comment."
                    android:textColor="#D7DEE8"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:linksClickable="true"
                    android:autoLink="web" />

            </LinearLayout>

            <!-- Metadata & Actions Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="5dp"
                android:layout_marginStart="8dp"
                android:gravity="center_vertical">

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/tv_reply_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2m"
                    android:textColor="#7F8A99"
                    android:textSize="11sp" />

                <!-- Like Count -->
                <TextView
                    android:id="@+id/tv_reply_likes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:minWidth="26dp"
                    android:layout_marginStart="8dp"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_badge_red_modern"
                    android:visibility="gone" />

                <!-- Like Button -->
                <TextView
                    android:id="@+id/tv_reply_like"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:text="Like"
                    android:textColor="#FF4D57"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_icon_circle_transparent" />

                <!-- Reply Button -->
                <TextView
                    android:id="@+id/tv_reply_reply"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginStart="6dp"
                    android:text="Reply"
                    android:textColor="#D7DEE8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_icon_circle_transparent" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>