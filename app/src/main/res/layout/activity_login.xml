<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="true"
    tools:context=".ui.theme.LoginActivity">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/backgroud"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_auth_screen_overlay"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/auth_top_cluster"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/login_title_top"
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:background="@drawable/round_container1"
                        android:contentDescription="App Icon"
                        android:elevation="8dp"
                        android:padding="10dp"
                        android:src="@mipmap/ic_launcher_round" />

                    <TextView
                        android:id="@+id/tv_auth_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Welcome Back"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_auth_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Sign in to continue your conversations"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <FrameLayout
                        android:id="@+id/auth_switch_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_auth_switch_container"
                        android:elevation="8dp"
                        android:padding="6dp">

                        <View
                            android:id="@+id/auth_tab_indicator"
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_auth_tab_active"
                            tools:ignore="UselessParent" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_sign_in_tab"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:minHeight="48dp"
                                android:text="Sign In"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_register"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:minHeight="48dp"
                                android:text="Sign Up"
                                android:textColor="@color/text_secondary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </FrameLayout>

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/auth_form_stage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:minHeight="560dp">

                    <LinearLayout
                        android:id="@+id/login_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_auth_card"
                        android:elevation="14dp"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_auth_input"
                            android:hint="Enter your email"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress"
                            android:minHeight="56dp"
                            android:paddingStart="18dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Password"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_auth_input"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="12dp"
                            android:hint="Enter your password"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:minHeight="56dp"
                            android:paddingStart="18dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_forgot_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="40dp"
                            android:text="Forgot Password?"
                            android:textColor="#2F6FE4"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_login_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text=""
                            android:textColor="#D32F2F"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/btn_login"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/bg_auth_button_glass"
                            android:backgroundTint="@null"
                            android:elevation="10dp"
                            android:insetBottom="0dp"
                            android:insetTop="0dp"
                            android:text="Sign In"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/register_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_auth_card"
                        android:elevation="14dp"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Username"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_username"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_auth_input"
                            android:hint="Choose a username"
                            android:imeOptions="actionNext"
                            android:inputType="text"
                            android:minHeight="56dp"
                            android:paddingStart="18dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Email"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_register_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_auth_input"
                            android:hint="Enter your email"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress"
                            android:minHeight="56dp"
                            android:paddingStart="18dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Password"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_register_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_auth_input"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="12dp"
                            android:hint="Create a password"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:minHeight="56dp"
                            android:paddingStart="18dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Confirm Password"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_auth_input"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="12dp"
                            android:hint="Confirm your password"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:minHeight="56dp"
                            android:paddingStart="18dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_register_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text=""
                            android:textColor="#D32F2F"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/btn_register"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/bg_auth_button_glass"
                            android:backgroundTint="@null"
                            android:elevation="10dp"
                            android:insetBottom="0dp"
                            android:insetTop="0dp"
                            android:text="Sign Up"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
