<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_obsidian_card"
        android:elevation="14dp"
        android:translationZ="10dp">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server Configuration"
            android:textSize="20sp"
            android:textColor="@color/md3_on_surface"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp" />

        <!-- Server IP -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server IP"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md3_on_surface"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_server_ip"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:inputType="text"
            android:hint="Enter server IP address"
            android:textSize="15sp"
            android:textColor="@color/md3_on_surface"
            android:textColorHint="@color/md3_on_surface_secondary"
            android:gravity="center_vertical"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textCursorDrawable="@null"
            android:layout_marginBottom="14dp" />

        <!-- Server Port -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Port"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md3_on_surface"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_server_port"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:inputType="number"
            android:hint="Enter server port"
            android:textSize="15sp"
            android:textColor="@color/md3_on_surface"
            android:textColorHint="@color/md3_on_surface_secondary"
            android:gravity="center_vertical"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textCursorDrawable="@null"
            android:layout_marginBottom="14dp" />

        <!-- Use HTTPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_option_row_dark"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Use HTTPS"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cb_use_https"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/md3_primary" />

        </LinearLayout>

        <!-- Use WSS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_option_row_dark"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Use WSS (WebSocket Secure)"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cb_use_wss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/md3_primary" />

        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical">

            <Button
                android:id="@+id/btn_cancel_server_config"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="92dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/dialog_button_secondary_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reject_button_modern"
                android:backgroundTint="@null"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="10dp"
                android:elevation="8dp"
                android:translationZ="5dp"
                android:stateListAnimator="@animator/btn_shadow_animator" />

            <Button
                android:id="@+id/btn_save_server_config"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="92dp"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="@color/dialog_button_filled_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_new_message_button"
                android:backgroundTint="@null"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:elevation="12dp"
                android:translationZ="8dp"
                android:stateListAnimator="@animator/btn_shadow_animator" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>