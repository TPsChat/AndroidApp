<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:minWidth="150dp"
    android:minHeight="160dp"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingTop="22dp"
    android:paddingBottom="20dp"
    android:background="@drawable/bg_obsidian_card"
    android:elevation="14dp"
    android:translationZ="10dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Recording Indicator with Pulse Animation -->
    <RelativeLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Pulsing ring 2 -->
        <View
            android:id="@+id/v_pulse_ring_2"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_centerInParent="true"
            android:background="@drawable/recording_indicator"
            android:alpha="0.18" />

        <!-- Pulsing ring 1 -->
        <View
            android:id="@+id/v_pulse_ring_1"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_centerInParent="true"
            android:background="@drawable/recording_indicator"
            android:alpha="0.32" />

        <!-- Center dark circle -->
        <View
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_icon_circle_dark"
            android:elevation="8dp"
            android:translationZ="5dp" />

        <!-- Recording dot -->
        <ImageView
            android:id="@+id/iv_recording_indicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerInParent="true"
            android:src="@drawable/recording_indicator"
            android:contentDescription="Recording"
            android:elevation="12dp"
            android:translationZ="8dp" />

    </RelativeLayout>

    <!-- Status Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recording"
        android:textSize="13sp"
        android:textColor="@color/md3_on_surface_secondary"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp" />

    <!-- Timer Display -->
    <TextView
        android:id="@+id/tv_recording_timer"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:minWidth="88dp"
        android:gravity="center"
        android:text="00:00"
        android:textSize="18sp"
        android:textColor="@color/md3_on_surface"
        android:textStyle="bold"
        android:background="@drawable/bg_soft_inset"
        android:elevation="8dp"
        android:translationZ="5dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp" />

</LinearLayout>