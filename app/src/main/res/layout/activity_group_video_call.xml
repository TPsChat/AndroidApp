<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top floating call info -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/transparent"
        android:elevation="14dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_message_field_shadow"
            android:elevation="12dp"
            android:translationZ="8dp">

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Group Call"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_participant_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 participant"
                android:textColor="#9AA4B2"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:background="@android:color/transparent"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="72dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_icon_circle_dark"
            android:elevation="12dp"
            android:translationZ="8dp" />

    </LinearLayout>

    <!-- Video participants grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_video_grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:clipToPadding="false"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/call_controls_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_video_participant" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="34dp"
        android:paddingBottom="34dp"
        android:background="@drawable/bg_empty_state_panel"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toTopOf="@id/rv_video_grid"
        app:layout_constraintBottom_toBottomOf="@id/rv_video_grid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@drawable/ic_video_call"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:tint="#FF4D57" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting for others to join..."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:gravity="center" />

    </LinearLayout>

    <!-- Floating call controls -->
    <LinearLayout
        android:id="@+id/call_controls_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="16dp"
        android:translationZ="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_mic"
            android:scaleType="centerInside"
            android:padding="14dp"
            android:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#FF4D57" />

        <ImageButton
            android:id="@+id/btn_camera_toggle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_video_call"
            android:scaleType="centerInside"
            android:padding="14dp"
            android:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#FF4D57" />

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_switch_camera"
            android:scaleType="centerInside"
            android:padding="14dp"
            android:elevation="14dp"
            android:translationZ="10dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#D7DEE8" />

        <ImageButton
            android:id="@+id/btn_end_call"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_send_circle_modern"
            android:src="@drawable/ic_end_call"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:elevation="16dp"
            android:translationZ="12dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#FFFFFF" />

    </LinearLayout>

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#D9000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#FF4D57" />

        <TextView
            android:id="@+id/tv_loading_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting to call..."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>