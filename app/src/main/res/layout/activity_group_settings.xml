<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header floating -->
    <LinearLayout
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="11dp"
            android:contentDescription="Back"
            app:tint="@color/md3_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group Settings"
                android:textColor="@color/md3_on_surface"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md3_on_surface_secondary"
                android:textSize="13sp"
                android:layout_marginTop="3dp"
                tools:text="My Awesome Group" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- Group Information Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_obsidian_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Group Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/md3_on_surface"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:id="@+id/option_view_group_info"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_option_row_dark"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="View Group Info"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/md3_on_surface" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_on_surface_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/option_change_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_option_row_dark"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Change Group Avatar"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/md3_on_surface" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_on_surface_secondary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Privacy Settings Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_obsidian_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/md3_on_surface"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Public Group"
                            android:textSize="16sp"
                            android:textColor="@color/md3_on_surface"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anyone can join this group"
                            android:textSize="12sp"
                            android:textColor="@color/md3_on_surface_secondary"
                            android:layout_marginTop="5dp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switch_public"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="@color/md3_primary"
                        android:trackTint="#33404D5A" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_privacy_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="When enabled, anyone can find and join this group. When disabled, only invited members can join."
                    android:textSize="12sp"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- Member Management Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_obsidian_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Member Management"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/md3_on_surface"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:id="@+id/option_add_members"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_option_row_dark"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_input_add"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add Members"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/md3_on_surface" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_on_surface_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/option_remove_members"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_option_row_dark"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Members"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/md3_on_surface" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_on_surface_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/option_join_requests"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_option_row_dark"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Join Requests"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/md3_on_surface" />

                    <TextView
                        android:id="@+id/tv_request_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="28dp"
                        android:gravity="center"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_badge_red_modern"
                        android:textColor="@color/md3_on_primary"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:text="0"
                        android:visibility="gone"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_on_surface_secondary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Danger Zone Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_obsidian_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Danger Zone"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:id="@+id/option_leave_group"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_danger_option_row"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_error" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Leave Group"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_error" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/option_delete_group"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_danger_option_row"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_delete"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/md3_error" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Delete Group"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_more"
                        app:tint="@color/md3_error" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>