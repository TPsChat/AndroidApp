<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header floating -->
    <LinearLayout
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="11dp"
            android:contentDescription="@string/back"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#FF4D57" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="@string/profile"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_save"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="76dp"
            android:gravity="center"
            android:text="@string/save"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_new_message_button"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator" />

    </LinearLayout>

    <!-- Profile Content -->
    <LinearLayout
        android:id="@+id/profile_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_empty_state_panel"
                android:paddingStart="20dp"
                android:paddingTop="22dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp"
                android:elevation="12dp"
                android:translationZ="8dp">

                <!-- Avatar Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="18dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/civ_avatar"
                        android:layout_width="106dp"
                        android:layout_height="106dp"
                        android:src="@drawable/ic_profile_placeholder"
                        android:elevation="12dp"
                        android:translationZ="8dp"
                        app:civ_border_width="2dp"
                        app:civ_border_color="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tv_change_avatar"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="@string/change_avatar"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FF4D57"
                        android:background="@drawable/bg_icon_circle_transparent"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Username Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/username"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="14dp"
                    android:inputType="text"
                    android:background="@drawable/bg_message_field_shadow"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7F8A99"
                    android:textCursorDrawable="@null"
                    android:textSize="15sp" />

                <!-- First Name Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/first_name"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_first_name"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="14dp"
                    android:inputType="textPersonName"
                    android:background="@drawable/bg_message_field_shadow"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7F8A99"
                    android:textCursorDrawable="@null"
                    android:textSize="15sp" />

                <!-- Last Name Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/last_name"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_last_name"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="14dp"
                    android:inputType="textPersonName"
                    android:background="@drawable/bg_message_field_shadow"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7F8A99"
                    android:textCursorDrawable="@null"
                    android:textSize="15sp" />

                <!-- Phone Number Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/phone_number"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_phone_number"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="14dp"
                    android:inputType="phone"
                    android:background="@drawable/bg_message_field_shadow"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7F8A99"
                    android:textCursorDrawable="@null"
                    android:textSize="15sp" />

                <!-- Bio Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bio"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_bio"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginBottom="18dp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:background="@drawable/bg_message_field_shadow"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7F8A99"
                    android:textCursorDrawable="@null"
                    android:textSize="15sp" />

                <!-- Friends Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_option_row_dark"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tv_friends_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Friends"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_friends"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none" />

                    <TextView
                        android:id="@+id/tv_no_friends"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No friends to show"
                        android:textSize="14sp"
                        android:textColor="#9AA4B2"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <!-- Posts Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_option_row_dark"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tv_posts_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Posts"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_posts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none" />

                    <TextView
                        android:id="@+id/tv_no_posts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No posts to show"
                        android:textSize="14sp"
                        android:textColor="#9AA4B2"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#FF4D57"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>