<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Floating Action Bar -->
    <LinearLayout
        android:id="@+id/top_action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/iv_close"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            android:padding="11dp"
            app:tint="@color/md3_primary" />

        <!-- User Profile Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_user_avatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_color="@color/md3_border_glow"
                app:civ_border_width="1.5dp" />

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="User Name"
                android:textColor="@color/md3_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_post"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="82dp"
            android:text="Post"
            android:textAllCaps="false"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/md3_on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_primary_pill"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:enabled="false" />

    </LinearLayout>

    <!-- Scrollable Content Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/top_action_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Text Input Card -->
            <EditText
                android:id="@+id/et_post_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="230dp"
                android:background="@drawable/bg_obsidian_card"
                android:hint="What's on your mind?"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:lineSpacingMultiplier="1.3"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:gravity="top|start"
                android:inputType="textCapSentences|textMultiLine"
                android:scrollbars="vertical"
                android:overScrollMode="always"
                android:textCursorDrawable="@null" />

            <!-- Embedded Original Post Card -->
            <include
                android:id="@+id/embedded_post_card"
                layout="@layout/item_embedded_post"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Attached Media Preview -->
            <LinearLayout
                android:id="@+id/ll_media_preview_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_obsidian_card"
                android:paddingTop="14dp">

                <TextView
                    android:id="@+id/tv_image_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="0 / 5 images"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:textSize="12sp" />

                <HorizontalScrollView
                    android:id="@+id/hsv_media_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:id="@+id/ll_media_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />

                </HorizontalScrollView>

            </LinearLayout>

            <!-- Privacy Settings Selector -->
            <LinearLayout
                android:id="@+id/ll_privacy_settings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_soft_inset">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_privacy"
                    app:tint="@color/md3_primary" />

                <TextView
                    android:id="@+id/tv_privacy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Public"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="@color/md3_secondary" />

            </LinearLayout>

            <!-- Location/Tagging Info -->
            <LinearLayout
                android:id="@+id/ll_location_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                android:background="@drawable/bg_obsidian_card">

                <!-- Location Info -->
                <LinearLayout
                    android:id="@+id/ll_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:id="@+id/tv_location"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Location name"
                        android:textColor="@color/md3_on_surface"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/iv_remove_location"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_circle_dark"
                        android:src="@drawable/ic_close"
                        android:contentDescription="Remove location"
                        android:padding="9dp"
                        app:tint="@color/md3_secondary" />

                </LinearLayout>

                <!-- Tagged Users Info -->
                <LinearLayout
                    android:id="@+id/ll_tagged_users"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_tag"
                        app:tint="@color/md3_primary" />

                    <TextView
                        android:id="@+id/tv_tagged_users"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Tagged users"
                        android:textColor="@color/md3_on_surface"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/iv_remove_tags"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_circle_dark"
                        android:src="@drawable/ic_close"
                        android:contentDescription="Remove tags"
                        android:padding="9dp"
                        app:tint="@color/md3_secondary" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Floating Utility Toolbar -->
    <LinearLayout
        android:id="@+id/bottom_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/iv_photo_video"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_image"
            android:contentDescription="Add photo or video"
            android:padding="10dp"
            app:tint="@color/md3_primary" />

        <ImageButton
            android:id="@+id/iv_tag_people"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_tag"
            android:contentDescription="Tag people"
            android:padding="10dp"
            app:tint="@color/md3_primary" />

        <ImageButton
            android:id="@+id/iv_location"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_location"
            android:contentDescription="Add location"
            android:padding="10dp"
            app:tint="@color/md3_primary" />

        <ImageButton
            android:id="@+id/iv_emoji"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_emoji_smile"
            android:contentDescription="Add emoji"
            android:padding="10dp"
            app:tint="@color/md3_secondary" />

        <ImageButton
            android:id="@+id/iv_more_options"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_more"
            android:contentDescription="More options"
            android:padding="10dp"
            app:tint="@color/md3_secondary" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>