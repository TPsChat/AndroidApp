<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen_dark"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/header_card"
        layout="@layout/component_flat_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Search -->
    <LinearLayout
        android:id="@+id/search_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_bar_height"
            android:background="@drawable/bg_glass_search"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/md3_primary"
                android:contentDescription="@string/search_icon_description"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/search_hint"
                android:inputType="text"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:textSize="15sp"
                android:gravity="center_vertical"
                android:textCursorDrawable="@null"
                tools:ignore="TouchTargetSizeCheck" />

        </LinearLayout>

    </LinearLayout>

    <!-- Tabs Bar -->
    <LinearLayout
        android:id="@+id/tabs_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:background="@drawable/bg_soft_inset"
        android:padding="@dimen/auth_switch_inner_padding"
        app:layout_constraintTop_toBottomOf="@id/search_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tab_requests"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target_min"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/friend_requests_tab_requests"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/tab_text_selector"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_friends"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target_min"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/friend_requests_tab_friends"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/tab_text_selector"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tabs_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <!-- Requests Container -->
            <LinearLayout
                android:id="@+id/container_requests"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/md3_primary" />

                <include
                    android:id="@+id/tv_no_requests"
                    layout="@layout/component_empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="@dimen/screen_edge_inset"
                    android:layout_marginEnd="@dimen/screen_edge_inset"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:visibility="gone"
                    android:contentDescription="@string/empty_friend_requests_cd" />

                <TextView
                    android:id="@+id/tv_requests_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/friend_requests_tab_requests"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/md3_on_surface"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="6dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_friend_requests"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="always"
                    android:scrollbars="none"
                    tools:itemCount="2"
                    tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_friend_request" />

            </LinearLayout>

            <!-- Friends Container -->
            <LinearLayout
                android:id="@+id/container_friends"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_friends_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/friend_requests_tab_friends"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/md3_on_surface"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="6dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_my_friends"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:scrollbars="none"
                    tools:itemCount="5"
                    tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_friend_compact" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>