<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:background="@drawable/bg_option_row_dark"
    android:clickable="true"
    android:focusable="true"
    android:elevation="8dp"
    android:translationZ="5dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Header: Avatar, Username, Arrow -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="10dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_embedded_avatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_profile_placeholder"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_color="#33FFFFFF"
            app:civ_border_width="1.5dp" />

        <!-- Username -->
        <TextView
            android:id="@+id/tv_embedded_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Original Author"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Arrow icon -->
        <ImageView
            android:id="@+id/iv_embedded_arrow"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_arrow_right"
            android:background="@drawable/bg_icon_circle_transparent"
            android:padding="8dp"
            app:tint="#FF4D57"
            android:contentDescription="View original post"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Full Content -->
    <TextView
        android:id="@+id/tv_embedded_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This is the original post content..."
        android:textColor="#D7DEE8"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:paddingBottom="10dp" />

    <!-- Media Container -->
    <FrameLayout
        android:id="@+id/fl_embedded_media"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="200dp"
        android:background="@drawable/bg_message_field_shadow"
        android:elevation="6dp"
        android:translationZ="4dp"
        android:visibility="gone"
        android:clipToPadding="true"
        android:clipChildren="true">

        <!-- Single Image -->
        <ImageView
            android:id="@+id/iv_embedded_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:visibility="gone" />

        <!-- Video Player -->
        <FrameLayout
            android:id="@+id/fl_embedded_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="300dp"
            android:visibility="gone"
            android:background="#05070A">

            <ImageView
                android:id="@+id/iv_embedded_video_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="300dp"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true" />

            <ImageButton
                android:id="@+id/iv_embedded_video_play"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_send_circle_modern"
                android:src="@drawable/ic_play"
                android:contentDescription="Play video"
                android:padding="17dp"
                android:elevation="12dp"
                android:translationZ="8dp"
                android:stateListAnimator="@animator/btn_shadow_animator"
                app:tint="#FFFFFF" />

        </FrameLayout>

    </FrameLayout>

</LinearLayout>