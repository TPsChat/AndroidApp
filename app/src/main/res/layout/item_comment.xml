<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Main Comment Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- User Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_comment_avatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="1.5dp"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Comment Content Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false">

            <!-- Comment Bubble -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:minWidth="130dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_option_row_dark"
                android:elevation="8dp"
                android:translationZ="5dp">

                <!-- Username -->
                <TextView
                    android:id="@+id/tv_comment_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:text="Username"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingBottom="5dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Comment Text Body -->
                <TextView
                    android:id="@+id/tv_comment_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="260dp"
                    android:text="This is a comment text that can span multiple lines and support emojis and links."
                    android:textColor="@color/md3_on_surface"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"
                    android:linksClickable="true"
                    android:autoLink="web"
                    android:longClickable="true" />

                <!-- Media Attachment -->
                <ImageView
                    android:id="@+id/iv_comment_media"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:maxHeight="200dp"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:visibility="gone"
                    android:background="@drawable/bg_soft_inset"
                    android:contentDescription="Comment media" />

            </LinearLayout>

            <!-- Action Bar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginStart="8dp"
                android:gravity="center_vertical">

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/tv_comment_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5m"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:textSize="12sp" />

                <!-- Like Button -->
                <TextView
                    android:id="@+id/tv_comment_like"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginStart="10dp"
                    android:text="Like"
                    android:textColor="@color/md3_primary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_icon_circle_transparent" />

                <!-- Reply Button -->
                <TextView
                    android:id="@+id/tv_comment_reply"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:text="Reply"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_icon_circle_transparent" />

                <!-- Reaction Icons -->
                <LinearLayout
                    android:id="@+id/ll_reaction_icons_inline"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:background="@drawable/bg_soft_inset"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_reaction_like"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👍"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_love"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤️"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_haha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😂"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_wow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😮"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_sad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😢"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_angry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😠"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Reaction Count -->
                <TextView
                    android:id="@+id/tv_comment_reaction_count"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:minWidth="28dp"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_badge_red_modern"
                    android:visibility="gone" />

                <!-- Three-dot Menu -->
                <ImageButton
                    android:id="@+id/iv_comment_menu"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_icon_circle_transparent"
                    android:src="@drawable/ic_more"
                    android:contentDescription="Comment options"
                    android:padding="7dp"
                    app:tint="@color/md3_secondary"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Reply Thread Indicator & Replies Container -->
    <LinearLayout
        android:id="@+id/ll_replies_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="54dp"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <!-- View Replies Link -->
        <TextView
            android:id="@+id/tv_view_replies"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="View 3 replies"
            android:textColor="@color/md3_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_icon_circle_transparent"
            android:visibility="gone" />

        <!-- Replies List -->
        <LinearLayout
            android:id="@+id/ll_replies_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Replies will be added here dynamically -->

        </LinearLayout>

    </LinearLayout>

</LinearLayout>