<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen_dark"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/header_card"
        style="@style/AppFlatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/component_back_button" />

        <TextView
            android:id="@+id/tv_title"
            style="@style/AppToolbarTitle"
            android:text="@string/title_activity_create_group" />

        <TextView
            android:id="@+id/tv_create"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_target_min"
            android:minWidth="82dp"
            android:gravity="center"
            android:text="@string/action_create"
            android:textAllCaps="false"
            android:textColor="@color/md3_on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_filter_pill_active" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Group Information Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:paddingTop="@dimen/dialog_padding_v"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_info_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Group Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_name_placeholder"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_group_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/group_name_hint"
                android:inputType="textCapWords"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:textCursorDrawable="@null"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Group Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_description_label"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_group_description"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:hint="@string/group_description_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="top|start"
                android:textCursorDrawable="@null"
                android:layout_marginBottom="16dp" />

            <!-- Public/Private Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/group_public_label"
                        android:textSize="16sp"
                        android:textColor="@color/md3_on_surface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/group_public_desc"
                        android:textSize="12sp"
                        android:textColor="@color/md3_on_surface_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_public"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/md3_primary"
                    android:trackTint="@color/switch_track_selector" />

            </LinearLayout>

        </LinearLayout>

        <!-- Friends Selection Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:paddingTop="@dimen/dialog_padding_v"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_select_friends"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_select_friends_hint"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Search Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_bar_height"
                android:background="@drawable/bg_glass_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/md3_primary" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/group_search_friends_hint"
                    android:textSize="15sp"
                    android:textColor="@color/md3_on_surface"
                    android:textColorHint="@color/md3_on_surface_secondary"
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:gravity="center_vertical"
                    android:textCursorDrawable="@null" />

            </LinearLayout>

            <include
                android:id="@+id/list_skeleton"
                layout="@layout/component_list_skeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Friends RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_friends"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:scrollbars="none" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>