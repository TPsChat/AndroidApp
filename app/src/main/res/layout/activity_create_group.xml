<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen_dark"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header floating -->
    <LinearLayout
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="11dp"
            android:contentDescription="Back"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="@color/md3_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="Create Group"
            android:textColor="@color/md3_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_create"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="82dp"
            android:gravity="center"
            android:text="Create"
            android:textAllCaps="false"
            android:textColor="@color/md3_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_new_message_button"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Group Information Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_obsidian_card"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:elevation="12dp"
            android:translationZ="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:layout_marginBottom="14dp" />

            <!-- Group Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group Name"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_group_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Enter group name"
                android:inputType="textCapWords"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:textCursorDrawable="@null"
                android:layout_marginBottom="14dp" />

            <!-- Group Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description (Optional)"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_group_description"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:hint="Enter group description"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="top|start"
                android:textCursorDrawable="@null"
                android:layout_marginBottom="16dp" />

            <!-- Public/Private Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Public Group"
                        android:textSize="16sp"
                        android:textColor="@color/md3_on_surface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anyone can join this group"
                        android:textSize="12sp"
                        android:textColor="@color/md3_on_surface_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_public"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/md3_primary"
                    android:trackTint="#33404D5A" />

            </LinearLayout>

        </LinearLayout>

        <!-- Friends Selection Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_obsidian_card"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="14dp"
            android:elevation="12dp"
            android:translationZ="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Friends"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select at least 2 friends to create a group"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="14dp" />

            <!-- Search Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp"
                android:elevation="8dp"
                android:translationZ="5dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/md3_primary" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search friends..."
                    android:textSize="15sp"
                    android:textColor="@color/md3_on_surface"
                    android:textColorHint="@color/md3_on_surface_secondary"
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:gravity="center_vertical"
                    android:textCursorDrawable="@null" />

            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/md3_primary"
                android:layout_marginBottom="8dp" />

            <!-- Friends RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_friends"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:scrollbars="none" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>