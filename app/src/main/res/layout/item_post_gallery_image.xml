<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_margin="3dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="false"
    app:cardBackgroundColor="@color/md3_surface_container">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#05070A">

        <ImageView
            android:id="@+id/iv_gallery_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Gallery image" />

        <!-- Overlay for more indicator -->
        <FrameLayout
            android:id="@+id/view_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false">

            <TextView
                android:id="@+id/tv_more_count"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="+5"
                android:textColor="@color/md3_on_surface"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_send_circle_modern"
                android:elevation="12dp"
                android:translationZ="8dp" />

        </FrameLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>