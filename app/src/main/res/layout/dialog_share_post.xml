<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="18dp"
        android:background="@drawable/bg_obsidian_card"
        android:elevation="14dp"
        android:translationZ="10dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Share Post"
            android:textSize="20sp"
            android:textColor="@color/md3_on_surface"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="18dp" />

        <!-- Share to Feed -->
        <LinearLayout
            android:id="@+id/option_share_to_feed"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_edit"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share to your Feed"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Send as Message -->
        <LinearLayout
            android:id="@+id/option_send_as_message"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_send"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send as Message"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share to Story -->
        <LinearLayout
            android:id="@+id/option_share_to_story"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_info"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share to Story"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share to Group/Page -->
        <LinearLayout
            android:id="@+id/option_share_to_group"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_group_icon"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share to Group/Page"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md3_border_subtle"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp" />

        <!-- Copy Link -->
        <LinearLayout
            android:id="@+id/option_copy_link"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_link"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Copy Link"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share to External Apps -->
        <LinearLayout
            android:id="@+id/option_share_external"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_link"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share to Other Apps"
                android:textSize="15sp"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>