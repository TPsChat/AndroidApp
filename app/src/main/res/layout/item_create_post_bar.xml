<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:padding="12dp"
    android:background="@drawable/bg_option_row_dark"
    android:elevation="8dp"
    android:translationZ="5dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Profile Picture and Input Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="10dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Profile Picture Thumbnail -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_post_profile_thumbnail"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_profile_placeholder"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="1.5dp" />

        <!-- What's on your mind? Input -->
        <LinearLayout
            android:id="@+id/ll_create_post_input"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="6dp"
            android:translationZ="4dp">

            <TextView
                android:id="@+id/tv_create_post_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What's on your mind?"
                android:textColor="@color/md3_on_surface_secondary"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Separator Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md3_border_subtle"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="10dp" />

    <!-- Quick Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Live Button -->
        <LinearLayout
            android:id="@+id/ll_live_post"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_icon_circle_transparent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="Live"
                android:textColor="@color/md3_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Photo Button -->
        <LinearLayout
            android:id="@+id/ll_photo_post"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_icon_circle_transparent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="Photo"
                android:textColor="@color/md3_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Video Button -->
        <LinearLayout
            android:id="@+id/ll_video_post"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_icon_circle_transparent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_video_call"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="Video"
                android:textColor="@color/md3_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>