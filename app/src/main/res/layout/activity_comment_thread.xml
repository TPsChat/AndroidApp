<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Floating Header -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="18dp"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/iv_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle_dark"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:padding="11dp"
                android:visibility="visible"
                android:elevation="12dp"
                android:translationZ="8dp"
                android:stateListAnimator="@animator/btn_shadow_animator"
                app:tint="#FF4D57" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="Comments"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Sorting Options -->
        <LinearLayout
            android:id="@+id/ll_sort_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_sort_relevant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Relevant"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_small_pill"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_sort_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Most Recent"
                android:textColor="#9AA4B2"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Original Post Summary -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_post_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/bg_empty_state_panel"
            android:elevation="10dp"
            android:translationZ="6dp">

            <!-- Post Author Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="10dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_post_author_avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile_placeholder"
                    android:elevation="8dp"
                    android:translationZ="5dp"
                    app:civ_border_color="#33FFFFFF"
                    app:civ_border_width="1.5dp" />

                <TextView
                    android:id="@+id/tv_post_author_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Author Name"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_post_content_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Post content preview..."
                android:textColor="#B7C0CC"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:ellipsize="end" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#FF4D57"
        app:layout_constraintTop_toBottomOf="@id/cv_post_summary"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="34dp"
        android:paddingBottom="34dp"
        android:visibility="gone"
        android:background="@drawable/bg_empty_state_panel"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toBottomOf="@id/cv_post_summary"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@android:drawable/ic_menu_recent_history"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="16dp"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:tint="#FF4D57" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No comments yet"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="19sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Be the first to comment!"
            android:textColor="#9AA4B2"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Comments RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_comments"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/cv_post_summary"
        app:layout_constraintBottom_toTopOf="@id/tv_load_more_comments"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Load More Comments Button -->
    <TextView
        android:id="@+id/tv_load_more_comments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View more comments"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_new_message_button"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:visibility="gone"
        android:elevation="12dp"
        android:translationZ="8dp"
        android:stateListAnimator="@animator/btn_shadow_animator"
        app:layout_constraintTop_toBottomOf="@id/rv_comments"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_reply_indicator" />

    <!-- Reply Indicator -->
    <LinearLayout
        android:id="@+id/ll_reply_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_reply_bar_dark"
        android:padding="12dp"
        android:visibility="gone"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="3dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_reply_line" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_replying_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Replying to"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF4D57" />

            <TextView
                android:id="@+id/tv_reply_target_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="14sp"
                android:textColor="#D7DEE8"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_cancel_reply"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_close"
            android:contentDescription="Cancel reply"
            android:padding="9dp"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#D7DEE8" />

    </LinearLayout>

    <!-- Comment Input Floating -->
    <LinearLayout
        android:id="@+id/ll_input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:elevation="14dp"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Comment Field -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_message_field_shadow"
            android:elevation="12dp"
            android:translationZ="8dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_comment_avatar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_color="#33FFFFFF"
                app:civ_border_width="1dp" />

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:minHeight="40dp"
                android:maxHeight="120dp"
                android:background="@android:color/transparent"
                android:hint="Write a comment..."
                android:textColorHint="#7F8A99"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:inputType="textCapSentences|textMultiLine"
                android:gravity="center_vertical|start"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textCursorDrawable="@null"
                android:scrollbars="vertical"
                android:overScrollMode="always" />

            <ImageButton
                android:id="@+id/iv_attach_media"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_circle_transparent"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Attach media"
                android:padding="8dp"
                android:visibility="visible"
                android:stateListAnimator="@animator/btn_shadow_animator"
                app:tint="#FF4D57" />

        </LinearLayout>

        <!-- Send Button Outside -->
        <ImageButton
            android:id="@+id/iv_send_comment"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_send_circle_modern"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send comment"
            android:padding="13dp"
            android:enabled="false"
            android:elevation="16dp"
            android:translationZ="12dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="#FFFFFF" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>