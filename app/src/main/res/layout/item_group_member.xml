<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="78dp"
        android:background="@drawable/bg_option_row_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:elevation="8dp"
        android:translationZ="5dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_member_avatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_profile_placeholder"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="1.5dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_member_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md3_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="John Doe" />

            <TextView
                android:id="@+id/tv_member_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="@color/md3_on_surface_secondary"
                android:textSize="12sp"
                android:textStyle="normal"
                tools:text="Member" />

        </LinearLayout>

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="More options"
            android:src="@android:drawable/ic_menu_more"
            android:background="@drawable/bg_icon_circle_transparent"
            android:padding="8dp"
            android:elevation="6dp"
            android:translationZ="4dp"
            app:tint="@color/md3_primary" />

    </LinearLayout>

</LinearLayout>