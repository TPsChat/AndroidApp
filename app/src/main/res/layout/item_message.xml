<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Sent Message -->
    <LinearLayout
        android:id="@+id/ll_sent_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginEnd="4dp"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Reply preview for sent message -->
            <LinearLayout
                android:id="@+id/ll_sent_reply_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:orientation="vertical"
                android:background="@drawable/bg_message_reply_sent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_sent_reply_thumb"
                    android:layout_width="82dp"
                    android:layout_height="54dp"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_soft_inset"
                    android:visibility="gone"
                    tools:src="@drawable/ic_profile_placeholder" />

                <TextView
                    android:id="@+id/tv_sent_reply_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    tools:text="Alice" />

                <TextView
                    android:id="@+id/tv_sent_reply_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="230dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    tools:text="Previous message content preview" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/fl_sent_bubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/tv_sent_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="270dp"
                    android:background="@drawable/bg_message_sent"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="22dp"
                    android:text="This is a sent message"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"
                    tools:text="This is a sent message" />

                <!-- Overlay reactions badge at bottom-end of bubble -->
                <ImageView
                    android:id="@+id/iv_sent_reaction_image"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone"
                    tools:src="@drawable/ic_launcher_foreground" />

            </FrameLayout>

            <!-- Voice Message Container (Sent) -->
            <include
                android:id="@+id/ll_sent_voice_message"
                layout="@layout/item_voice_message_sent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Edited label for sent message -->
            <TextView
                android:id="@+id/tv_sent_edited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="(edited)"
                android:textSize="10sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_sent_image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_sent_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="250dp"
                    android:maxHeight="300dp"
                    android:minWidth="130dp"
                    android:minHeight="130dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_image_message_sent"
                    android:padding="2dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground" />

                <ImageView
                    android:id="@+id/iv_sent_image_reaction"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_sent_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="6dp"
                android:text="10:30 AM"
                android:textSize="10sp"
                android:textColor="@color/md3_on_surface_secondary"
                tools:text="10:30 AM" />

        </LinearLayout>

    </LinearLayout>

    <!-- Received Message -->
    <LinearLayout
        android:id="@+id/ll_received_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_marginStart="4dp"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_sender_avatar"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="7dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_width="1.2dp"
            app:civ_border_color="@color/md3_border_glow" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Reply preview for received message -->
            <LinearLayout
                android:id="@+id/ll_received_reply_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:orientation="vertical"
                android:background="@drawable/bg_message_reply_received"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_received_reply_thumb"
                    android:layout_width="82dp"
                    android:layout_height="54dp"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_soft_inset"
                    android:visibility="gone"
                    tools:src="@drawable/ic_profile_placeholder" />

                <TextView
                    android:id="@+id/tv_received_reply_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    tools:text="Bob" />

                <TextView
                    android:id="@+id/tv_received_reply_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="230dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    tools:text="Previous message content preview" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_sender_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md3_on_surface_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="3dp"
                android:visibility="gone"
                tools:text="Alice" />

            <FrameLayout
                android:id="@+id/fl_received_bubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/tv_received_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="270dp"
                    android:background="@drawable/bg_message_received"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="22dp"
                    android:text="This is a received message"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"
                    tools:text="This is a received message" />

                <!-- Overlay reactions badge at bottom-end of bubble -->
                <ImageView
                    android:id="@+id/iv_received_reaction_image"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone"
                    tools:src="@drawable/ic_launcher_foreground" />

            </FrameLayout>

            <!-- Voice Message Container (Received) -->
            <include
                android:id="@+id/ll_received_voice_message"
                layout="@layout/item_voice_message_received"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Edited label for received message -->
            <TextView
                android:id="@+id/tv_received_edited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="6dp"
                android:text="(edited)"
                android:textSize="10sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_received_image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_received_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="250dp"
                    android:maxHeight="300dp"
                    android:minWidth="130dp"
                    android:minHeight="130dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_image_message_received"
                    android:padding="2dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground" />

                <ImageView
                    android:id="@+id/iv_received_image_reaction"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_received_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="6dp"
                android:text="10:30 AM"
                android:textSize="10sp"
                android:textColor="@color/md3_on_surface_secondary"
                tools:text="10:30 AM" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>