<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/spacing_xs"
    android:layout_marginEnd="@dimen/spacing_xs"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="86dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_obsidian_card"
        android:gravity="center_vertical"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_call_avatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_width="1.5dp"
            app:civ_border_color="@color/md3_border_glow" />

        <!-- Call Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name and Call Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_call_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mateo Castillo"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/md3_on_surface"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_call_type_icon"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:text="VID"
                    android:textSize="15sp"
                    android:background="@drawable/bg_icon_circle_transparent" />

            </LinearLayout>

            <!-- Status and Duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_call_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Completed"
                    android:textSize="13sp"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_call_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2:30"
                    android:textSize="13sp"
                    android:textColor="@color/md3_on_surface"
                    android:layout_marginStart="@dimen/spacing_xs" />

            </LinearLayout>

        </LinearLayout>

        <!-- Time and Action -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_call_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:30"
                android:textSize="12sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginBottom="8dp" />

            <ImageButton
                android:id="@+id/btn_call_action"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_send_circle_modern"
                android:src="@drawable/ic_call"
                android:contentDescription="Call"
                android:scaleType="centerInside"
                android:padding="10dp"
                app:tint="@color/md3_on_surface" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>