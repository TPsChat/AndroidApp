<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header floating, không có bar nền -->
    <LinearLayout
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:padding="11dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="Back"
            app:tint="@color/md3_primary" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_profile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_view"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="1.5dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_chat_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/henry_arthur_name"
                android:textColor="@color/md3_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Typing..."
                android:textColor="@color/md3_on_surface_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_video_call"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="@string/video_call_description"
            android:src="@drawable/ic_video_call"
            android:padding="10dp"
            android:scaleType="centerInside"
            app:tint="@color/md3_primary" />

        <ImageButton
            android:id="@+id/iv_cancel_call"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="Cancel call"
            android:src="@drawable/ic_decline_call"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:visibility="gone"
            app:tint="@color/md3_primary" />

        <ImageButton
            android:id="@+id/iv_more"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="@string/more_options_description"
            android:src="@drawable/ic_more_feedback"
            android:padding="10dp"
            app:tint="@color/md3_secondary" />

    </LinearLayout>

    <!-- Offline Indicator -->
    <LinearLayout
        android:id="@+id/offline_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:background="@drawable/bg_indicator_error"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="@color/md3_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Internet Connection"
            android:textColor="@color/md3_on_surface"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Summarize Button -->
    <LinearLayout
        android:id="@+id/summarize_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_indicator_primary"
        app:layout_constraintTop_toBottomOf="@id/offline_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/md3_on_surface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summarize Chat"
            android:textColor="@color/md3_on_surface"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Group Call Active Notification -->
    <LinearLayout
        android:id="@+id/group_call_notification"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_indicator_primary"
        app:layout_constraintTop_toBottomOf="@id/summarize_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_video_call"
            app:tint="@color/md3_on_surface" />

        <TextView
            android:id="@+id/tv_group_call_notification_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Group video call in progress"
            android:textColor="@color/md3_on_surface"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAP TO JOIN"
            android:textColor="@color/md3_on_surface"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/bg_small_pill" />

    </LinearLayout>

    <!-- Messages Area -->
    <LinearLayout
        android:id="@+id/messages_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/group_call_notification"
        app:layout_constraintBottom_toTopOf="@id/reply_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_messages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:scrollbars="none" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_scroll_to_bottom"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="14dp"
                android:text="↓ Tin nhắn mới"
                android:textColor="@color/md3_on_surface"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_new_message_button"
                android:visibility="gone"
                android:minWidth="0dp"
                android:minHeight="0dp" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/typing_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone"
            android:background="@drawable/bg_new_message_button">

            <ProgressBar
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Typing..."
                android:textColor="@color/md3_on_primary"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Reply Bar -->
    <LinearLayout
        android:id="@+id/reply_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/bg_reply_bar_dark"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/message_input_card"
        app:layout_constraintTop_toBottomOf="@id/messages_card">

        <View
            android:layout_width="3dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_reply_line" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_reply_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                tools:text="Alice" />

            <TextView
                android:id="@+id/tv_reply_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textSize="12sp"
                android:textColor="@color/md3_on_surface"
                tools:text="Previous message content preview" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_reply_close"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="Close reply"
            android:src="@drawable/ic_close"
            android:padding="9dp"
            app:tint="@color/md3_secondary" />

    </LinearLayout>

    <!-- Message Input floating -->
    <!-- Message Input floating -->
    <LinearLayout
        android:id="@+id/message_input_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/transparent">

            <!-- Ô nhập tin nhắn dạng pill có đổ bóng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/bg_soft_inset">

                <ImageButton
                    android:id="@+id/iv_sticker"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_icon_circle_transparent"
                    android:contentDescription="@string/send_sticker_description"
                    android:src="@drawable/ic_emoji_smile"
                    android:padding="8dp"
                    app:tint="@color/md3_primary" />

                <EditText
                    android:id="@+id/et_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="Type a message"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="4"
                    android:minHeight="40dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="@color/md3_on_surface"
                    android:textColorHint="@color/md3_on_surface_secondary"
                    android:textCursorDrawable="@null"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/iv_attach"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_icon_circle_transparent"
                    android:contentDescription="@string/attach_file_description"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:padding="8dp"
                    app:tint="@color/md3_primary" />

                <!-- Nút mic nằm bên trong -->
                <ImageButton
                    android:id="@+id/record_audio_button"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_icon_circle_transparent"
                    android:contentDescription="@string/record_audio_description"
                    android:src="@drawable/ic_mic_voice"
                    android:padding="8dp"
                    app:tint="@color/md3_primary" />

            </LinearLayout>

            <!-- Nút send nằm bên ngoài -->
            <ImageButton
                android:id="@+id/iv_send"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_send_circle_modern"
                android:contentDescription="@string/send_message_description"
                android:src="@drawable/ic_send"
                android:padding="13dp"
                app:tint="@color/text_white" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>