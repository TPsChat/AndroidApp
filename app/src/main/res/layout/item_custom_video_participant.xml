<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="10dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#151B24">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="#05070A"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Video frame ImageView -->
        <ImageView
            android:id="@+id/iv_video_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Placeholder when video is off -->
        <LinearLayout
            android:id="@+id/video_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#101722"
            android:visibility="visible">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_participant_avatar"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:src="@drawable/ic_profile_placeholder"
                android:elevation="12dp"
                android:translationZ="8dp"
                app:civ_border_color="#33FFFFFF"
                app:civ_border_width="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Camera Off"
                android:textColor="#9AA4B2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Connection quality indicator -->
        <ImageView
            android:id="@+id/iv_connection_quality"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="10dp"
            android:src="@drawable/ic_signal"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="8dp"
            android:elevation="10dp"
            android:translationZ="6dp"
            android:visibility="gone"
            app:tint="#22C55E" />

        <!-- Bottom info overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradient_overlay"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_participant_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="User Name"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Muted indicator -->
            <ImageView
                android:id="@+id/iv_muted_indicator"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_mic_off"
                android:background="@drawable/bg_icon_circle_dark"
                android:padding="8dp"
                android:elevation="10dp"
                android:translationZ="6dp"
                android:visibility="gone"
                app:tint="#FF4D57" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>