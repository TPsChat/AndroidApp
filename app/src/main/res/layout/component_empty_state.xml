<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="@dimen/spacing_lg">

    <ImageView
        android:id="@+id/iv_empty_icon"
        android:layout_width="@dimen/avatar_md"
        android:layout_height="@dimen/avatar_md"
        android:importantForAccessibility="no"
        android:visibility="gone"
        tools:src="@drawable/ic_chat"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_empty_title"
        style="@style/AppHeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        tools:text="No messages yet" />

    <TextView
        android:id="@+id/tv_empty_subtitle"
        style="@style/AppBodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center"
        android:textColor="@color/md3_on_surface_secondary"
        tools:text="Start a conversation to see it here." />

</LinearLayout>
