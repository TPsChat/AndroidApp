<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="18dp"
        android:background="@drawable/bg_obsidian_card"
        android:elevation="14dp"
        android:translationZ="10dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reactions"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/md3_on_surface"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="18dp" />

        <!-- Reactions Container -->
        <LinearLayout
            android:id="@+id/container_reactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="110dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:elevation="8dp"
            android:translationZ="5dp" />

        <!-- Close Button -->
        <LinearLayout
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_gravity="end"
            android:layout_marginTop="14dp"
            android:minWidth="92dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:background="@drawable/bg_reject_button_modern"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:stateListAnimator="@animator/btn_shadow_animator">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLOSE"
                android:textColor="@color/dialog_button_secondary_text"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>