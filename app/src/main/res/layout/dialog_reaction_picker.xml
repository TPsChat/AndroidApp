<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_empty_state_panel"
    android:elevation="14dp"
    android:translationZ="10dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Like -->
    <TextView
        android:id="@+id/tv_reaction_like_picker"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:text="👍"
        android:textSize="30sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="Like" />

    <!-- Love -->
    <TextView
        android:id="@+id/tv_reaction_love_picker"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="4dp"
        android:text="❤️"
        android:textSize="30sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="Love" />

    <!-- Haha -->
    <TextView
        android:id="@+id/tv_reaction_haha_picker"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="4dp"
        android:text="😂"
        android:textSize="30sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="Haha" />

    <!-- Wow -->
    <TextView
        android:id="@+id/tv_reaction_wow_picker"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="4dp"
        android:text="😮"
        android:textSize="30sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="Wow" />

    <!-- Sad -->
    <TextView
        android:id="@+id/tv_reaction_sad_picker"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="4dp"
        android:text="😢"
        android:textSize="30sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="Sad" />

    <!-- Angry -->
    <TextView
        android:id="@+id/tv_reaction_angry_picker"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="4dp"
        android:text="😠"
        android:textSize="30sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="Angry" />

</LinearLayout>