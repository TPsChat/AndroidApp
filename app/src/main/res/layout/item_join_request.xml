<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_option_row_dark"
        android:elevation="8dp"
        android:translationZ="5dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_profile_placeholder"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_width="1.5dp"
            app:civ_border_color="#33FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Username with a reasonably long name" />

            <TextView
                android:id="@+id/tv_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9AA4B2"
                android:textSize="13sp"
                android:layout_marginTop="5dp"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Join request for 'Awesome Group'" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btn_approve"
                android:layout_width="92dp"
                android:layout_height="38dp"
                android:text="Approve"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_new_message_button"
                android:backgroundTint="@null"
                android:elevation="10dp"
                android:translationZ="6dp"
                android:stateListAnimator="@animator/btn_shadow_animator"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                tools:ignore="TouchTargetSizeCheck" />

            <Button
                android:id="@+id/btn_reject"
                android:layout_width="92dp"
                android:layout_height="38dp"
                android:layout_marginTop="8dp"
                android:text="Reject"
                android:textAllCaps="false"
                android:textColor="#FF4D57"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reject_button_modern"
                android:backgroundTint="@null"
                android:elevation="8dp"
                android:translationZ="5dp"
                android:stateListAnimator="@animator/btn_shadow_animator"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                tools:ignore="TouchTargetSizeCheck" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>