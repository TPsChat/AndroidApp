<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.08"
        android:scaleType="centerCrop"
        android:contentDescription="@string/background_image_cd"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Flat search header -->
    <LinearLayout
        android:id="@+id/search_header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_flat_header"
        android:gravity="center_vertical"
        android:minHeight="@dimen/header_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="@string/back_button_description"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_back"
            app:tint="@color/md3_primary" />

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/search_bar_height"
            android:layout_weight="1"
            android:background="@drawable/bg_glass_search">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="@string/search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="@dimen/dialog_padding_h"
                android:paddingEnd="48dp"
                android:singleLine="true"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:textCursorDrawable="@null"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/iv_clear"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:background="@drawable/bg_icon_circle_transparent"
                android:contentDescription="@string/clear_search_cd"
                android:padding="@dimen/icon_button_inset"
                android:src="@drawable/ic_close"
                android:visibility="gone"
                app:tint="@color/md3_primary" />

        </RelativeLayout>

    </LinearLayout>

    <!-- Search Tabs -->
    <LinearLayout
        android:id="@+id/search_tabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:background="@drawable/bg_soft_inset"
        android:orientation="horizontal"
        android:padding="@dimen/auth_switch_inner_padding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_header_card">

        <TextView
            android:id="@+id/tab_users"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target_min"
            android:layout_weight="1"
            android:text="@string/search_tab_users"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_groups"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target_min"
            android:layout_weight="1"
            android:text="@string/search_tab_my_groups"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_discover"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target_min"
            android:layout_weight="1"
            android:text="@string/search_tab_discover"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_posts"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target_min"
            android:layout_weight="1"
            android:text="@string/search_tab_posts"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Search Filters -->
    <HorizontalScrollView
        android:id="@+id/filters_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_tabs">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/filter_friends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target_min"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="@string/search_filter_friends"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/filter_media"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target_min"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="@string/search_filter_media"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/filter_hashtag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target_min"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="@string/search_filter_hashtag"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/filter_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target_min"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="@string/search_filter_date"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filters_container">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="6dp"
                android:paddingBottom="8dp"
                android:scrollbars="none"
                android:background="@android:color/transparent"
                android:visibility="gone" />

            <!-- Search Hint -->
            <LinearLayout
                android:id="@+id/tv_search_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/screen_edge_inset"
                android:layout_marginEnd="@dimen/screen_edge_inset"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="34dp"
                android:paddingBottom="34dp"
                android:background="@drawable/bg_soft_inset">

                <ImageView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@drawable/ic_search"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="16dp"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:tint="@color/md3_primary"
                    android:contentDescription="@string/search_icon_description" />

                <TextView
                    android:id="@+id/tv_hint_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_hint_title"
                    android:textSize="20sp"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_hint_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_hint_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:textAlignment="center"
                    android:gravity="center" />

            </LinearLayout>

            <!-- No Results -->
            <LinearLayout
                android:id="@+id/tv_no_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/screen_edge_inset"
                android:layout_marginEnd="@dimen/screen_edge_inset"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="34dp"
                android:paddingBottom="34dp"
                android:visibility="gone"
                android:background="@drawable/bg_soft_inset">

                <ImageView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@drawable/ic_help"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="16dp"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:tint="@color/md3_primary"
                    android:contentDescription="@string/no_results_cd" />

                <TextView
                    android:id="@+id/tv_no_results_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_no_results_title"
                    android:textSize="20sp"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_no_results_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_no_results_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:textAlignment="center"
                    android:gravity="center" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/md3_primary" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>