<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        android:contentDescription="Background Image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Search Header Floating -->
    <LinearLayout
        android:id="@+id/search_header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="Back"
            android:padding="11dp"
            android:src="@drawable/ic_back"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="@color/md3_primary" />

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_glass_search">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="Search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="18dp"
                android:paddingEnd="48dp"
                android:singleLine="true"
                android:textColor="@color/md3_on_surface"
                android:textColorHint="@color/md3_on_surface_secondary"
                android:textCursorDrawable="@null"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/iv_clear"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_icon_circle_transparent"
                android:contentDescription="Clear search text"
                android:padding="7dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:visibility="gone"
                android:stateListAnimator="@animator/btn_shadow_animator"
                app:tint="@color/md3_primary" />

        </RelativeLayout>

    </LinearLayout>

    <!-- Search Tabs -->
    <LinearLayout
        android:id="@+id/search_tabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:padding="6dp"
        android:background="@drawable/bg_soft_inset"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_header_card">

        <TextView
            android:id="@+id/tab_users"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Users"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_groups"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="My Groups"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_discover"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Discover"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_posts"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Posts"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:textColor="@color/tab_text_selector"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Search Filters -->
    <HorizontalScrollView
        android:id="@+id/filters_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:visibility="gone"
        android:scrollbars="none"
        android:elevation="10dp"
        android:translationZ="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_tabs">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/filter_friends"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="Friends Only"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/filter_media"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="Media Only"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/filter_hashtag"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="Hashtags"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/filter_date"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_option_row_dark"
                android:text="Date Range"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/filters_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="6dp"
                android:paddingBottom="8dp"
                android:scrollbars="none"
                android:background="@android:color/transparent"
                android:visibility="gone" />

            <!-- Search Hint -->
            <LinearLayout
                android:id="@+id/tv_search_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="34dp"
                android:paddingBottom="34dp"
                android:background="@drawable/bg_obsidian_card"
                android:elevation="12dp"
                android:translationZ="8dp">

                <ImageView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="16dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="8dp"
                    android:translationZ="5dp"
                    app:tint="@color/md3_primary"
                    android:contentDescription="Search Icon" />

                <TextView
                    android:id="@+id/tv_hint_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start searching"
                    android:textSize="20sp"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_hint_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter a keyword to find results"
                    android:textSize="14sp"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:textAlignment="center"
                    android:gravity="center" />

            </LinearLayout>

            <!-- No Results -->
            <LinearLayout
                android:id="@+id/tv_no_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="34dp"
                android:paddingBottom="34dp"
                android:visibility="gone"
                android:background="@drawable/bg_obsidian_card"
                android:elevation="12dp"
                android:translationZ="8dp">

                <ImageView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="16dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="8dp"
                    android:translationZ="5dp"
                    app:tint="@color/md3_primary"
                    android:contentDescription="No Results Icon" />

                <TextView
                    android:id="@+id/tv_no_results_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No users found"
                    android:textSize="20sp"
                    android:textColor="@color/md3_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_no_results_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Try searching with a different email or username"
                    android:textSize="14sp"
                    android:textColor="@color/md3_on_surface_secondary"
                    android:textAlignment="center"
                    android:gravity="center" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/md3_primary" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>