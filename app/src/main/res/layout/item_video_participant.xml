<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/spacing_xs"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="@dimen/spacing_xs"
    android:layout_marginBottom="4dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@drawable/bg_obsidian_card"
        android:clipChildren="false"
        android:clipToPadding="false">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/video_stage">

            <org.webrtc.SurfaceViewRenderer
                android:id="@+id/sv_participant_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/video_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/video_stage_soft"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_participant_avatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_profile_placeholder"
                    app:civ_border_color="@color/md3_border_glow"
                    app:civ_border_width="2dp" />

                <TextView
                    android:id="@+id/tv_participant_name_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="User"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Camera Off"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_connection_quality"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:background="@drawable/bg_icon_circle_dark"
                android:padding="8dp"
                android:src="@drawable/ic_signal"
                android:visibility="gone"
                app:tint="@color/success_color" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_overlay"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="10dp">

                <TextView
                    android:id="@+id/tv_participant_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="User Name"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_muted_indicator"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="8dp"
                    android:src="@drawable/ic_mic_off"
                    android:visibility="gone"
                    app:tint="@color/md3_primary" />

                <ImageView
                    android:id="@+id/iv_speaking_indicator"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="8dp"
                    android:src="@drawable/ic_volume"
                    android:visibility="gone"
                    app:tint="@color/success_color" />

            </LinearLayout>

        </FrameLayout>

    </RelativeLayout>

</FrameLayout>
