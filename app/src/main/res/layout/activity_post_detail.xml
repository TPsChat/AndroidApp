<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen_dark"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Floating App Bar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/transparent"
        android:elevation="14dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:padding="11dp"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="@color/md3_primary" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="Post"
            android:textColor="@color/md3_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        app:layout_constraintBottom_toTopOf="@id/ll_reply_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- Full Post Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_full_post"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:background="@drawable/bg_obsidian_card"
                        android:elevation="12dp"
                        android:translationZ="8dp">

                        <!-- Header Block -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="12dp">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/iv_post_avatar"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_profile_placeholder"
                                android:elevation="8dp"
                                android:translationZ="5dp"
                                app:civ_border_color="@color/md3_border_glow"
                                app:civ_border_width="1.5dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/tv_post_username"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="John Doe"
                                        android:textColor="@color/md3_on_surface"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tv_post_tagged_users"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:text=""
                                        android:textColor="@color/md3_primary"
                                        android:textSize="16sp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:background="@drawable/bg_icon_circle_transparent"
                                        android:visibility="gone" />

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tv_post_timestamp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="2 hours ago"
                                    android:textColor="@color/md3_on_surface_secondary"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <ImageButton
                                android:id="@+id/iv_post_menu"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_dark"
                                android:src="@drawable/ic_more"
                                android:contentDescription="Post options"
                                android:padding="9dp"
                                android:elevation="8dp"
                                android:translationZ="5dp"
                                android:stateListAnimator="@animator/btn_shadow_animator"
                                app:tint="@color/md3_secondary" />

                        </LinearLayout>

                        <!-- Content Body -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingBottom="12dp">

                            <TextView
                                android:id="@+id/tv_post_content"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="This is a sample post content."
                                android:textColor="@color/md3_on_surface"
                                android:textSize="15sp"
                                android:lineSpacingMultiplier="1.2"
                                android:paddingBottom="10dp" />

                            <FrameLayout
                                android:id="@+id/fl_post_media"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="200dp"
                                android:visibility="gone"
                                android:background="@drawable/bg_option_row_dark"
                                android:clipToOutline="true">

                                <ImageView
                                    android:id="@+id/iv_post_image"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:scaleType="centerCrop"
                                    android:adjustViewBounds="true"
                                    android:visibility="gone" />

                                <androidx.recyclerview.widget.RecyclerView
                                    android:id="@+id/rv_post_gallery"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone"
                                    android:scrollbars="none" />

                                <FrameLayout
                                    android:id="@+id/fl_post_video"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:minHeight="300dp"
                                    android:visibility="gone"
                                    android:background="@android:color/black">

                                    <ImageView
                                        android:id="@+id/iv_post_video_thumbnail"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:scaleType="centerCrop"
                                        android:adjustViewBounds="true" />

                                    <ImageButton
                                        android:id="@+id/iv_post_video_play"
                                        android:layout_width="64dp"
                                        android:layout_height="64dp"
                                        android:layout_gravity="center"
                                        android:background="@drawable/bg_send_circle_modern"
                                        android:src="@drawable/ic_play"
                                        android:contentDescription="Play video"
                                        android:padding="18dp"
                                        android:elevation="12dp"
                                        android:translationZ="8dp"
                                        android:stateListAnimator="@animator/btn_shadow_animator"
                                        app:tint="@color/md3_on_surface" />

                                </FrameLayout>

                            </FrameLayout>

                        </LinearLayout>

                        <!-- Interaction Summary -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp">

                            <LinearLayout
                                android:id="@+id/ll_likes_summary"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@android:drawable/btn_star_big_on"
                                    app:tint="@color/md3_primary" />

                                <TextView
                                    android:id="@+id/tv_likes_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:text="1.2K"
                                    android:textColor="@color/md3_on_surface_secondary"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_comments_count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="245 comments"
                                android:textColor="@color/md3_on_surface_secondary"
                                android:textSize="14sp"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="end"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tv_shares_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12 shares"
                                android:textColor="@color/md3_on_surface_secondary"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/md3_border_subtle"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="6dp" />

                        <!-- Action Bar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:id="@+id/ll_like_button"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="@drawable/bg_icon_circle_transparent">

                                <ImageView
                                    android:id="@+id/iv_like_icon"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@android:drawable/btn_star_big_off"
                                    app:tint="@color/md3_primary" />

                                <TextView
                                    android:id="@+id/tv_like_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Like"
                                    android:textColor="@color/md3_on_surface"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_comment_button"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="@drawable/bg_icon_circle_transparent">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="@color/md3_primary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Comment"
                                    android:textColor="@color/md3_on_surface"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_share_button"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="@drawable/bg_icon_circle_transparent">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@android:drawable/ic_menu_share"
                                    app:tint="@color/md3_primary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Share"
                                    android:textColor="@color/md3_on_surface"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Comments Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="14dp">

                    <TextView
                        android:id="@+id/tv_comments_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Comments"
                        android:textColor="@color/md3_on_surface"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="10dp" />

                    <ProgressBar
                        android:id="@+id/progress_loading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/md3_primary"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/ll_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="28dp"
                        android:paddingEnd="28dp"
                        android:paddingTop="34dp"
                        android:paddingBottom="34dp"
                        android:visibility="gone"
                        android:background="@drawable/bg_obsidian_card"
                        android:elevation="12dp"
                        android:translationZ="8dp">

                        <ImageView
                            android:layout_width="68dp"
                            android:layout_height="68dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            android:background="@drawable/bg_icon_circle_dark"
                            android:padding="16dp"
                            app:tint="@color/md3_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="No comments yet"
                            android:textColor="@color/md3_on_surface"
                            android:textStyle="bold"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Be the first to comment!"
                            android:textColor="@color/md3_on_surface_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_comments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="8dp"
                        android:nestedScrollingEnabled="false"
                        android:scrollbars="none" />

                    <TextView
                        android:id="@+id/tv_load_more_comments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="View more comments"
                        android:textColor="@color/md3_on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_new_message_button"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="9dp"
                        android:paddingBottom="9dp"
                        android:visibility="gone"
                        android:elevation="12dp"
                        android:translationZ="8dp"
                        android:stateListAnimator="@animator/btn_shadow_animator"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Reply Indicator -->
    <LinearLayout
        android:id="@+id/ll_reply_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_reply_bar_dark"
        android:padding="12dp"
        android:visibility="gone"
        android:elevation="12dp"
        android:translationZ="8dp"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="3dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_reply_line" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_replying_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Replying to"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md3_primary" />

            <TextView
                android:id="@+id/tv_reply_target_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="14sp"
                android:textColor="@color/md3_on_surface"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_cancel_reply"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_close"
            android:contentDescription="Cancel reply"
            android:padding="9dp"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="@color/md3_secondary" />

    </LinearLayout>

    <!-- Comment Input Floating -->
    <LinearLayout
        android:id="@+id/ll_input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:elevation="14dp"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_soft_inset"
            android:elevation="12dp"
            android:translationZ="8dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_comment_avatar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_color="@color/md3_border_glow"
                app:civ_border_width="1dp" />

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:minHeight="40dp"
                android:maxHeight="120dp"
                android:background="@android:color/transparent"
                android:hint="Write a comment..."
                android:textColorHint="@color/md3_on_surface_secondary"
                android:textColor="@color/md3_on_surface"
                android:textSize="14sp"
                android:inputType="textCapSentences|textMultiLine"
                android:gravity="center_vertical|start"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textCursorDrawable="@null"
                android:scrollbars="vertical"
                android:overScrollMode="always" />

            <ImageButton
                android:id="@+id/iv_attach_media"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_circle_transparent"
                android:src="@drawable/ic_camera"
                android:contentDescription="Attach media"
                android:padding="8dp"
                android:visibility="visible"
                android:stateListAnimator="@animator/btn_shadow_animator"
                app:tint="@color/md3_primary" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_send_comment"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_send_circle_modern"
            android:src="@drawable/ic_send"
            android:contentDescription="Send comment"
            android:padding="13dp"
            android:enabled="false"
            android:elevation="16dp"
            android:translationZ="12dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            app:tint="@color/md3_on_surface" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>