<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_obsidian_card"
        android:elevation="8dp"
        android:translationZ="5dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Group Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_group_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_group_avatar"
            android:elevation="8dp"
            android:translationZ="5dp"
            app:civ_border_color="@color/md3_border_glow"
            app:civ_border_width="1.5dp" />

        <!-- Group Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Group Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Group Name" />

            <TextView
                android:id="@+id/tv_member_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 members"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginTop="5dp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="12 members" />

            <TextView
                android:id="@+id/tv_last_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No messages yet"
                android:textSize="13sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginTop="5dp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="No messages yet" />

        </LinearLayout>

        <!-- Action Button for Discover tab -->
        <Button
            android:id="@+id/btn_group_action"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="92dp"
            android:text="Join"
            android:textAllCaps="false"
            android:textColor="@color/md3_on_surface"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:background="@drawable/bg_new_message_button"
            android:backgroundTint="@null"
            android:elevation="10dp"
            android:translationZ="6dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>