<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="18dp"
        android:background="@drawable/bg_empty_state_panel"
        android:elevation="14dp"
        android:translationZ="10dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tag People"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="18dp" />

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_message_field_shadow"
            android:elevation="8dp"
            android:translationZ="5dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="12dp"
                app:tint="#FF4D57" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search friends..."
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#7F8A99"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:gravity="center_vertical"
                android:textCursorDrawable="@null" />

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="16dp"
            android:indeterminateTint="#FF4D57"
            android:visibility="gone" />

        <!-- No Friends Message -->
        <TextView
            android:id="@+id/tv_no_friends"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No friends found"
            android:textSize="15sp"
            android:textColor="#D7DEE8"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:background="@drawable/bg_option_row_dark"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:visibility="gone" />

        <!-- Friends List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:orientation="vertical"
            android:background="@drawable/bg_option_row_dark"
            android:elevation="8dp"
            android:translationZ="5dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_friends"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="true"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:scrollbars="none"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- Done Button -->
        <Button
            android:id="@+id/btn_done"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Done"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_new_message_button"
            android:backgroundTint="@null"
            android:elevation="12dp"
            android:translationZ="8dp"
            android:stateListAnimator="@animator/btn_shadow_animator"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

</LinearLayout>