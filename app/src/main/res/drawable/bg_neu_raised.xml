<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="1dp">
        <shape>
            <solid android:color="@color/neu_shadow" />
            <corners android:radius="@dimen/radius_lg" />
        </shape>
    </item>
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="@color/neu_surface_raised" />
            <corners android:radius="@dimen/radius_lg" />
            <stroke
                android:width="1dp"
                android:color="#18FFFFFF" />
        </shape>
    </item>
</layer-list>
