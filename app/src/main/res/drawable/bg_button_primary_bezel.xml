<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="@color/palette_wine"
                android:startColor="@color/palette_crimson" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item
        android:bottom="@dimen/radius_pill"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/border_highlight" />
            <corners
                android:topLeftRadius="@dimen/radius_pill"
                android:topRightRadius="@dimen/radius_pill" />
        </shape>
    </item>
</layer-list>
