<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_surface_sunken" />
            <corners android:radius="@dimen/radius_lg" />
            <stroke
                android:width="1dp"
                android:color="@color/md3_border_subtle" />
        </shape>
    </item>
    <item
        android:bottom="@dimen/radius_lg"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/border_highlight" />
            <corners
                android:topLeftRadius="@dimen/radius_lg"
                android:topRightRadius="@dimen/radius_lg" />
        </shape>
    </item>
</layer-list>
