<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="1dp">
        <shape>
            <solid android:color="@color/md3_ripple" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <gradient
                android:angle="135"
                android:endColor="@color/palette_wine"
                android:startColor="@color/palette_crimson" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
</layer-list>
