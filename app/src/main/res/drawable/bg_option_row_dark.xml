<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#22FFFFFF">

    <item>
        <layer-list>

            <item
                android:left="1dp"
                android:right="1dp"
                android:top="4dp"
                android:bottom="0dp">
                <shape>
                    <solid android:color="#55000000" />
                    <corners android:radius="18dp" />
                </shape>
            </item>

            <item
                android:left="0dp"
                android:right="0dp"
                android:top="0dp"
                android:bottom="4dp">
                <shape>
                    <solid android:color="#D91E252E" />
                    <corners android:radius="18dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#1FFFFFFF" />
                </shape>
            </item>

        </layer-list>
    </item>

</ripple>