<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#D6EFF8FF"
                android:startColor="#F2FFFFFF" />
            <corners android:radius="32dp" />
            <stroke
                android:width="1dp"
                android:color="#C6FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#18FFFFFF"
                android:startColor="#36FFFFFF" />
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="#36B7D9EF" />
        </shape>
    </item>
</layer-list>
