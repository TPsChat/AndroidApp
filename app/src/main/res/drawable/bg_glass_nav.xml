<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="2dp"
        android:top="4dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#88000000" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="4dp">
        <shape>
            <solid android:color="@color/palette_charcoal" />
            <corners android:radius="@dimen/radius_pill" />
            <stroke
                android:width="1dp"
                android:color="#14FFFFFF" />
        </shape>
    </item>
</layer-list>
