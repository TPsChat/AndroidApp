<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item
                android:left="0dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="0dp">
                <shape>
                    <solid android:color="@color/md3_ripple" />
                    <corners android:radius="@dimen/radius_pill" />
                </shape>
            </item>
            <item
                android:left="0dp"
                android:top="0dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:endColor="@color/palette_wine"
                        android:startColor="@color/palette_crimson" />
                    <corners android:radius="@dimen/radius_pill" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
</selector>
