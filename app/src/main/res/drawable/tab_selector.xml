<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape>
            <gradient
                android:startColor="#FF6A72"
                android:centerColor="#FF4D57"
                android:endColor="#D93645"
                android:angle="270" />
            <corners android:radius="100dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#001E252E" />
            <corners android:radius="100dp" />
        </shape>
    </item>

</selector>