<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#BE1184CD"
                android:startColor="#D621C9D5" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#28FFFFFF" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
