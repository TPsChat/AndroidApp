<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/md3_ripple">
    <item>
        <layer-list>
            <item
                android:left="1dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="1dp">
                <shape android:shape="oval">
                    <solid android:color="#0D0F172A" />
                </shape>
            </item>
            <item
                android:left="0dp"
                android:top="0dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="oval">
                    <solid android:color="@color/neu_surface_raised" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/md3_border_subtle" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
