<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">

    <item>
        <layer-list>

            <item
                android:left="2dp"
                android:right="2dp"
                android:top="4dp"
                android:bottom="0dp">
                <shape android:shape="oval">
                    <solid android:color="#80000000" />
                </shape>
            </item>

            <item
                android:left="0dp"
                android:right="0dp"
                android:top="0dp"
                android:bottom="4dp">
                <shape android:shape="oval">
                    <solid android:color="#26303B" />
                    <stroke
                        android:width="1dp"
                        android:color="#1FFFFFFF" />
                </shape>
            </item>

        </layer-list>
    </item>

</ripple>