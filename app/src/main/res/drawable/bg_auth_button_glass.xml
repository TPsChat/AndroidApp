<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#D1146FC8"
                android:startColor="#E11FC8D7" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#D8FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#04FFFFFF"
                android:startColor="#34FFFFFF" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
