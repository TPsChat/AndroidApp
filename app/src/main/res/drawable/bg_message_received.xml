<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="3dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#55000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#D91E252E" />
            <stroke
                android:width="1dp"
                android:color="#1FFFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>

</layer-list>
